# Database
DATABASE_URL="postgresql://lms:secret@localhost:5432/knightlead_lms?schema=public"

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-32-bytes-of-base64-random"
AUTH_URL="http://localhost:3000"
# Set when deploying behind a trusted proxy / different domain.
AUTH_TRUST_HOST="true"

# Optional OAuth providers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Object storage (for assignment attachments, course thumbnails)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# Rate limiting (use Upstash in production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Mail (Resend recommended; falls back to console in dev)
RESEND_API_KEY=""
MAIL_FROM="Knightlead Solutions <noreply@example.com>"

# File storage
UPLOAD_DIR="uploads"
